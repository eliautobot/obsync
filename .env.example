# By default, create the administrator username/password in the browser on first launch.
# For unattended bootstrap only, set both values, start Obsync once, then remove them from .env.
OBSYNC_ADMIN_USERNAME=
OBSYNC_ADMIN_PASSWORD=

# Set true when the browser reaches Obsync exclusively over HTTPS.
OBSYNC_SECURE_COOKIES=false

# Headless initial setup only: comma-separated trusted management IPs.
# Remove this immediately after registering the administrator account.
OBSYNC_LOCAL_SETUP_IPS=

# Pre-0.2 upgrades only. Existing deployments may keep their old value until the browser
# completes the one-time migration to username/password login.
OBSYNC_ADMIN_TOKEN=

# Absolute host path to your Obsidian vault.
OBSYNC_VAULT_HOST_PATH=./vault
# Public/LAN URL agents should use to reach this server. Optional when the
# browser is already opened through a reachable address.
OBSYNC_PUBLIC_URL=
OBSYNC_BIND_IP=0.0.0.0
PUID=1000
PGID=1000

# The path inside the server container. Keep this unless customizing Docker.
OBSYNC_VAULT_PATH=/vault
OBSYNC_DATA_DIR=/data
OBSYNC_PORT=7769
OBSYNC_MAX_UPLOAD_MB=100
OBSYNC_MAX_EXTRACT_CHARS=200000
OBSYNC_LOG_LEVEL=info
